# Copy this file to .env and fill in your values

# MongoDB connection string
# Local:  mongodb://localhost:27017/drivepro
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/drivepro?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/drivepro

# JWT signing secret — change this in production
JWT_SECRET=drivepro_secret_change_in_production

# Port
PORT=3001

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

NODE_ENV=development
